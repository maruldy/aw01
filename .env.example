# ===== App =====
APP_ENV=development
ADMIN_TOKEN=local-admin

# ===== LLM =====
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_MODEL=gpt-4o-mini

# ===== Jira Self-Hosted Enterprise =====
JIRA_BASE_URL=https://jira.your-company.internal
JIRA_API_TOKEN=
JIRA_USERNAME=you@example.com
JIRA_PROJECTS=PROJ,OPS

# ===== Confluence Self-Hosted Enterprise =====
CONFLUENCE_URL=https://confluence.your-company.internal
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACES=ENG,OPS

# ===== Slack Enterprise Grid =====
SLACK_BOT_TOKEN=
SLACK_USER_TOKEN=
SLACK_MY_USER_ID=

# ===== GitHub Enterprise Cloud =====
GITHUB_BASE_URL=https://api.github.com
GITHUB_TOKEN=
GITHUB_REPOSITORY=owner/repo

# ===== Storage =====
KNOWLEDGE_DB_PATH=./data/work_harness.db
KNOWLEDGE_CHROMA_PATH=./data/chroma
MANAGED_WORKSPACE_ROOT=./.workspaces

# ===== Bootstrap =====
AUTO_BOOTSTRAP=false
BOOTSTRAP_MONTHS_BACK=6

# ===== Scheduler =====
DAILY_DELTA_SCAN_HOUR=3
WEEKLY_DIGEST_DAY=mon
WEEKLY_DIGEST_HOUR=9

# ===== Frontend =====
VITE_API_BASE_URL=http://localhost:8000
